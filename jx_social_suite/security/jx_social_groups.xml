    <!-- jx.social.token - Strict No Direct Access -->
    <record id="jx_social_token_no_direct_access" model="ir.rule">
        <field name="name">JX Social Token: No Direct Access</field>
        <field name="model_id" ref="model_jx_social_token"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[(0,'=',1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- jx.social.audit - Read Only + Agency Scope -->
    <record id="jx_social_audit_readonly_rule" model="ir.rule">
        <field name="name">JX Social Audit: Read Only + Agency Scope</field>
        <field name="model_id" ref="model_jx_social_audit"/>
        <field name="groups" eval="[
    (4, ref('jx_social_suite.jx_social_group_agency_admin')),
    (4, ref('jx_social_suite.jx_social_group_agency_user'))
]"/>
        <field name="domain_force">[('partner_id.commercial_partner_id', 'in', user.commercial_partner_id.child_ids.ids)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>